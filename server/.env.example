# Skyline Travel Planner — train proxy config
# Copy this file to  .env  and fill in your real key. NEVER commit the real .env.

# Required: your RapidAPI key (from rapidapi.com, under the train API you subscribed to)
RAPIDAPI_KEY=your_rapidapi_key_here

# --- Flights: Travelpayouts (Aviasales data + affiliate commission) ---
# Token from travelpayouts.com -> Developers/API tokens.
TRAVELPAYOUTS_TOKEN=PASTE_YOUR_TRAVELPAYOUTS_API_TOKEN_HERE
# Your affiliate marker/partner ID (needed to EARN commission on bookings).
TRAVELPAYOUTS_MARKER=PASTE_YOUR_TRAVELPAYOUTS_MARKER_HERE

# Optional: only change these if your RapidAPI product is NOT "IRCTC1".
# RAPIDAPI_HOST=irctc1.p.rapidapi.com
# RAPIDAPI_STATION_PATH=/api/v1/searchStation?query={q}
# RAPIDAPI_TRAINS_PATH=/api/v3/trainBetweenStations?fromStationCode={from}&toStationCode={to}&dateOfJourney={date}


# Optional: port for this proxy (default 3001)
# TRAIN_API_PORT=3001
